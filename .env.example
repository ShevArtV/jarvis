TELEGRAM_TOKEN=your_token_here
ALLOWED_USER_IDS=comma,separated,user,ids

# Дефолтный движок LLM для новых топиков: claude (дефолт), codex или opencode.
# Существующие топики хранят свой движок в БД; переключить активный топик можно
# командой /engine <name> в самом Telegram (новый session_id под новый движок,
# cwd сохраняется, контекст прежнего диалога не переносится).
# JARVIS_ENGINE=claude

# Бинарники и таймауты — по умолчанию ищутся в PATH.
# CLAUDE_BIN=claude
# CLAUDE_TIMEOUT=3600
# CODEX_BIN=codex
# CODEX_TIMEOUT=3600
# OPENCODE_BIN=opencode
# OPENCODE_TIMEOUT=3600

# Опционально для opencode: если не заданы, берутся из opencode config.
# OPENCODE_MODEL=anthropic/claude-sonnet-4-5
# OPENCODE_AGENT=build
# OPENCODE_VARIANT=high

# Дефолтный cwd для топиков без /bind.
# CLAUDE_CWD=/home/shevartv
